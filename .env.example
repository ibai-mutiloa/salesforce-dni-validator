# Salesforce Identity Validator - Environment Configuration
# Copy this file to .env and update with your actual values

# ==============================================================================
# API Configuration
# ==============================================================================
DEBUG=False
API_TITLE=Salesforce Identity Validator
API_VERSION=1.0.0
API_DESCRIPTION=Validates Salesforce user registrations against identity documents

# ==============================================================================
# Azure Document Intelligence Configuration
# ==============================================================================
AZURE_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com
AZURE_API_KEY=your-api-key-here
AZURE_API_VERSION=2024-11-30
AZURE_ANALYZER_ID=prebuilt-idDocument

# ==============================================================================
# Validation Configuration
# ==============================================================================
# Minimum fuzzy matching score required for names to match (0-100)
MIN_NAME_MATCH_SCORE=85.0

# Azure polling configuration
POLLING_MAX_ATTEMPTS=60
POLLING_INTERVAL_MS=2000

# ==============================================================================
# Logging Configuration
# ==============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==============================================================================
# Security Configuration
# ==============================================================================
# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=["*"]

# Optional API keys for authentication
API_KEYS=[]
