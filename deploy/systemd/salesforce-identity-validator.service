[Unit]
Description=Salesforce Identity Validator API
After=network.target

[Service]
Type=simple
User=administrador
WorkingDirectory=/home/administrador/SalesforceIdentityValidator
EnvironmentFile=/home/administrador/SalesforceIdentityValidator/.env
ExecStart=/home/administrador/SalesforceIdentityValidator/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target